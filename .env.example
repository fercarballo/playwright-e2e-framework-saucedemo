# ─────────────────────────────────────────────────────────────
# Variables de entorno de ejemplo.
# Copiá este archivo a ".env" y ajustá los valores si lo necesitás:
#     cp .env.example .env
#
# El archivo ".env" está en .gitignore: NUNCA se sube al repo.
# Así mantenemos secretos y URLs fuera del control de versiones.
# ─────────────────────────────────────────────────────────────

# URL base de la aplicación bajo prueba.
# Si no se define, el framework usa https://www.saucedemo.com por defecto.
BASE_URL=https://www.saucedemo.com
