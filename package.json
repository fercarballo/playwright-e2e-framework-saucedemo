{
  "name": "playwright-e2e-framework-saucedemo",
  "version": "1.0.0",
  "description": "Framework E2E de referencia con Playwright + TypeScript sobre SauceDemo. Proyecto de portfolio para QA Automation Sr.",
  "author": "Fernando Carballo",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:headed": "playwright test --headed --project=chromium",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.saucedemo.com"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa-automation",
    "e2e-testing",
    "page-object-model",
    "test-automation"
  ],
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3"
  }
}
